# Authentication
AUTH_USERNAME=olam
AUTH_PASSWORD=changeme
JWT_SECRET=change-this-to-a-random-32-char-string

# Google Sheets
GOOGLE_SHEETS_SPREADSHEET_ID=your-spreadsheet-id-from-url
GOOGLE_SHEETS_SHEET_NAME=Sheet1
GOOGLE_SERVICE_ACCOUNT_EMAIL=your-sa@your-project.iam.gserviceaccount.com
GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# Scraper
SCRAPER_BOROUGH=3
SCRAPER_DELAY_MS=1000
SCRAPER_ASSESSMENT_MODE=asmt_tent_2027

# Optional: Zapier webhook for sync completion notifications
ZAPIER_WEBHOOK_URL=
